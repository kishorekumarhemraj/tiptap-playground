{
  "name": "@tiptap-playground/editor",
  "version": "0.1.0",
  "description": "Notion-style TipTap editor for regulated document management - driver-injected, UI-agnostic core with optional React bindings.",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "default": "./src/react.ts"
    },
    "./drivers": {
      "types": "./src/drivers/index.ts",
      "default": "./src/drivers/index.ts"
    },
    "./extensions": {
      "types": "./src/extensions/index.ts",
      "default": "./src/extensions/index.ts"
    },
    "./styles.css": "./src/react/styles.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extensions": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "yjs": "^13.6.0"
  },
  "peerDependenciesMeta": {
    "yjs": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@tiptap/extension-collaboration": "^3.22.4",
    "@tiptap/extension-collaboration-caret": "^3.22.4"
  },
  "dependencies": {
    "@tiptap/suggestion": "^3.22.4"
  }
}
